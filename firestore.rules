rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null 
        && request.auth.token.email == 'alartqaaschool@gmail.com';
    }

    function isPortalOpen() {
      return get(/databases/$(database)/documents/config/settings).data.registrationOpen == true;
    }

    function isValidStudentForm() {
      let d = request.resource.data;
      return
        d.keys().hasAll([
          'fullName', 'dob', 'gender', 'grade', 'parentName',
          'phone', 'registeredAt'
        ]) &&
        d.fullName is string && d.fullName.size() >= 3 && d.fullName.size() <= 150 &&
        d.parentName is string && d.parentName.size() >= 3 && d.parentName.size() <= 150 &&
        d.phone is string && d.phone.size() >= 10 && d.phone.size() <= 20 &&
        d.gender in ['ذكر', 'أنثى'] &&
        d.grade is string &&
        d.registeredAt == request.time;
    }

    function isValidPhoneReg() {
      let d = request.resource.data;
      return (!d.names || (d.names is list && d.names.size() <= 50)) &&
             (!d.count || (d.count is number && d.count >= 0 && d.count <= 100));
    }

    function isValidStatsWrite() {
      let d = request.resource.data;
      // السماح بالكتابة للإحصاءات مع التحقق من صحة البيانات
      return (d.total is number && d.total >= 0 && d.total <= 1000000) &&
             (d.male is number && d.male >= 0) &&
             (d.female is number && d.female >= 0) &&
             (!d.deletedCount || (d.deletedCount is number && d.deletedCount >= 0));
    }

    match /students/{studentId} {
      allow read, update, delete: if isAdmin();
      allow create: if isPortalOpen() && isValidStudentForm();
    }

    match /config/settings {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if true;
    }

    match /config/stats {
      allow read: if true;
      allow write: if isAdmin() || (request.resource.data.size() <= 12 && isValidStatsWrite());
    }

    match /config/phoneRegistry/{phone} {
      allow read: if true;
      allow write: if isAdmin() || isValidPhoneReg();
    }

    match /logs/{logId} {
      allow read, delete: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
